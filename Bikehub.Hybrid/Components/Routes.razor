@inject NavigationManager Navigation

<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(MauiProgram).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData">
                <NotAuthorized>
                    <AuthorizeView >
                        <Authorized Context="authContext">
                            
                            <div style="padding:40px; text-align:center;">
                                <h2 style="margin-bottom:8px;">Access denied</h2>
                                <p style="color:#666;">You do not have permission to view this page.</p>
                                
                            </div>
                        </Authorized>
                       
                        <NotAuthorized Context="unauthContext">
                                <LayoutView Layout="@typeof(Layout.EmptyLayout)">
                                    <Bikehub.Hybrid.Components.Pages.Login />
                                </LayoutView>
                        </NotAuthorized>
                    </AuthorizeView>
                 
                </NotAuthorized>
                
                <Authorizing>
                    <LayoutView Layout="@typeof(Layout.EmptyLayout)">
                        <div style="display:flex; justify-content:center; align-items:center; height:100vh;">
                            <p>Loading...</p>
                        </div>
                    </LayoutView>
                </Authorizing>

            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <LayoutView Layout="@typeof(Layout.MainLayout)">
                <p role="alert">Sorry, there's nothing at this address.</p>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>

