@inject AuthService Auth

<div class="login-screen">
    <div class="login-bg">
        <div class="login-gear g1">⚙</div>
        <div class="login-gear g2">⚙</div>
        <div class="login-gear g3">⚙</div>
    </div>

    <div class="login-card">
        <div class="login-logo">
            <span class="login-logo-icon">🚲</span>
            <div>
                <div class="login-brand">BikeHub</div>
                <div class="login-tagline">Internal Management System</div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(error))
        {
            <div class="login-error">@error</div>
        }

        <div class="login-form">
            <div class="form-group">
                <label>Email Address</label>
                <input type="email" @bind="email" placeholder="you@bikehub.com" class="form-input" />
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" @bind="password" placeholder="••••••••" class="form-input"
                       @onkeydown="HandleKey" />
            </div>
            <button class="btn-login" @onclick="DoLogin" disabled="@loading">
                @(loading ? "Signing in..." : "Sign In")
            </button>
        </div>

        <div class="login-hints">
            <div class="hint-title">Demo Accounts</div>
            <div class="hint-row" @onclick='()=>QuickFill("admin@bikehub.com","admin123")'><span class="hint-role admin">Admin</span> admin@bikehub.com / admin123</div>
            <div class="hint-row" @onclick='()=>QuickFill("staff@bikehub.com","staff123")'><span class="hint-role staff">Staff</span> staff@bikehub.com / staff123</div>
            <div class="hint-row" @onclick='()=>QuickFill("mechanic@bikehub.com","mech123")'><span class="hint-role mech">Mechanic</span> mechanic@bikehub.com / mech123</div>
        </div>
    </div>
</div>

@code {
    string email = "", password = "", error = "";
    bool loading = false;

    void QuickFill(string e, string p) { email = e; password = p; }

    async Task HandleKey(KeyboardEventArgs e) { if (e.Key == "Enter") await DoLogin(); }

    async Task DoLogin()
    {
        loading = true; error = "";
        var ok = await Auth.LoginAsync(email, password);
        if (!ok) error = "Invalid email or password.";
        loading = false;
    }
}
