@inject DataService Data
@inject AuthService Auth

<div class="page-content">
    <div class="mech-welcome">
        <div class="mw-icon">🔧</div>
        <div>
            <div class="mw-title">Workshop Dashboard</div>
            <div class="mw-sub">Hey @Auth.CurrentUser?.Name! Here's your workload today.</div>
        </div>
    </div>

    <div class="stat-grid">
        <StatCard Label="Assigned Tasks" Value="@Tasks.Count(t => t.Status == TaskStatusEnum.Assigned).ToString()" Icon="📌" Color="blue" Delta="New" Pos="true" />
        <StatCard Label="In Progress" Value="@Tasks.Count(t => t.Status == TaskStatusEnum.InProgress).ToString()" Icon="⚙" Color="orange" Delta="Active" Pos="true" />
        <StatCard Label="Completed Today" Value="@Tasks.Count(t => t.Status == TaskStatusEnum.Completed && t.CompletedAt?.Date == DateTime.Today).ToString()" Icon="✅" Color="green" Delta="Done" Pos="true" />
        <StatCard Label="Total Tasks"     Value="@Tasks.Count.ToString()"                                       Icon="📋" Color="red"    Delta="All time" Pos="true" />
    </div>

    <div class="card">
        <div class="card-header">
            <div><div class="card-title">Active Tasks</div><div class="card-sub">Your current workload</div></div>
        </div>
        @foreach (var t in Tasks.Where(t => t.Status != TaskStatusEnum.Completed).OrderBy(t => t.Status))
        {
        <div class="task-row priority-@t.Priority.ToLower()">
            <div class="task-priority-bar"></div>
            <div class="task-info">
                <div class="task-order">@t.OrderNumber</div>
                <div class="task-customer">@t.CustomerName</div>
                <div class="task-desc">@t.Description</div>
            </div>
            <div class="task-meta">
                <span class="task-priority">@t.Priority</span>
                <span class="task-status ts-@t.Status.ToString().ToLower()">@t.Status</span>
            </div>
            <div class="task-assigned">Assigned @t.AssignedAt.ToString("MMM d")</div>
        </div>
        }
        @if (!Tasks.Any(t => t.Status != TaskStatusEnum.Completed))
        {
            <div class="empty-state">🎉 All tasks completed!</div>
        }
    </div>
</div>

@code {
    List<MechanicTask> Tasks => Data.Tasks.Where(t => t.MechanicId == Auth.CurrentUser?.Id).ToList();
}
