<span class="status-badge @CssClass()">@Status</span>

@code {
    [Parameter] public OrderStatus Status { get; set; }
    string CssClass() => Status switch
    {
        OrderStatus.Pending        => "s-pending",
        OrderStatus.Confirmed      => "s-confirmed",
        OrderStatus.InService      => "s-inservice",
        OrderStatus.ReadyForPickup => "s-ready",
        OrderStatus.Completed      => "s-completed",
        OrderStatus.Cancelled      => "s-cancelled",
        _ => ""
    };
}
