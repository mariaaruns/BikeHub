<div class="perm-section">
    <div class="perm-section-title">@Icon @Title</div>
    <div class="perm-toggles">
        @foreach (var (label, value, key) in Perms)
        {
            <label class="perm-toggle">
                <input type="checkbox" checked="@value"
                       @onchange="e => OnToggle.InvokeAsync((key, (bool)e.Value!))" />
                <span class="toggle-track"><span class="toggle-thumb"></span></span>
                <span class="toggle-label">@label</span>
            </label>
        }
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Icon  { get; set; } = "";
    [Parameter] public (string Label, bool Value, string Key)[] Perms { get; set; } = Array.Empty<(string,bool,string)>();
    [Parameter] public EventCallback<(string, bool)> OnToggle { get; set; }
}
