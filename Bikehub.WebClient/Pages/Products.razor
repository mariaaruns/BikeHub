@page "/products"
@inject DataService Data
@inject AuthService Auth

<div class="page-content">
    <div class="page-toolbar">
        <input class="tb-search-inp" type="text" placeholder="🔍 Search products..." @bind="search" @bind:event="oninput" />
        <select class="tb-filter" @bind="catFilter">
            <option value="">All Categories</option>
            @foreach (var c in Data.Categories)
            { <option value="@c.Id">@c.Name</option> }
        </select>
        @if (Auth.HasPermission(p=>p.CanCreateProducts))
        {
            <button class="btn-primary" @onclick="()=>OpenForm(null)">+ Add Product</button>
        }
    </div>

    <div class="product-grid">
    @foreach (var p in Filtered)
    {
        <div class="product-card">
            <div class="pc-image">@p.ImageUrl</div>
            <div class="pc-body">
                <div class="pc-name">@p.Name</div>
                <div class="pc-meta">
                    <span class="pc-brand">@p.BrandName</span>
                    <span class="pc-cat">@p.CategoryName</span>
                </div>
                <div class="pc-bottom">
                    <div class="pc-price">$@p.Price.ToString("N0")</div>
                    <div class="pc-stock @(p.Stock<5?"low-stock":"")">@p.Stock in stock</div>
                </div>
            </div>
            <div class="pc-actions">
                @if (Auth.HasPermission(p2=>p2.CanEditProducts))
                { <button class="act-btn edit" @onclick="()=>OpenForm(p)">✎</button> }
                @if (Auth.HasPermission(p2=>p2.CanDeleteProducts))
                { <button class="act-btn del" @onclick="()=>DeleteProduct(p.Id)">✕</button> }
            </div>
        </div>
    }
    @if (!Filtered.Any())
    { <div class="empty-state">No products found.</div> }
    </div>
</div>

@if (showForm)
{
    <div class="modal-overlay" @onclick="CloseForm">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header">
                <div class="modal-title">@(editing==null?"Add Product":"Edit Product")</div>
                <button class="modal-close" @onclick="CloseForm">✕</button>
            </div>
            <div class="modal-body">
                <div class="form-row two">
                    <div class="form-group">
                        <label>Product Name *</label>
                        <input class="form-input" @bind="form.Name" placeholder="e.g. Trek Marlin 7" />
                    </div>
                    <div class="form-group">
                        <label>Price ($) *</label>
                        <input class="form-input" type="number" @bind="form.Price" />
                    </div>
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <textarea class="form-input" rows="2" @bind="form.Description"></textarea>
                </div>
                <div class="form-row two">
                    <div class="form-group">
                        <label>Category</label>
                        <select class="form-input" @bind="form.CategoryId" @bind:after="SyncCatName">
                            @foreach (var c in Data.Categories)
                            { <option value="@c.Id">@c.Name</option> }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Brand</label>
                        <select class="form-input" @bind="form.BrandId" @bind:after="SyncBrandName">
                            @foreach (var b in Data.Brands)
                            { <option value="@b.Id">@b.Name</option> }
                        </select>
                    </div>
                </div>
                <div class="form-row two">
                    <div class="form-group">
                        <label>Stock</label>
                        <input class="form-input" type="number" @bind="form.Stock" />
                    </div>
                    <div class="form-group">
                        <label>Image (emoji / URL)</label>
                        <input class="form-input" @bind="form.ImageUrl" placeholder="🚲" />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-ghost" @onclick="CloseForm">Cancel</button>
                <button class="btn-primary" @onclick="Save">@(editing==null?"Add Product":"Save Changes")</button>
            </div>
        </div>
    </div>
}

@code {
    string search = "", catFilter = "";
    bool showForm; Product? editing; Product form = new();

    IEnumerable<Product> Filtered => Data.Products
        .Where(p => string.IsNullOrEmpty(search) || p.Name.Contains(search, StringComparison.OrdinalIgnoreCase))
        .Where(p => string.IsNullOrEmpty(catFilter) || p.CategoryId.ToString() == catFilter);

    void OpenForm(Product? p)
    {
        editing = p;
        form = p == null ? new Product { CategoryId=Data.Categories.FirstOrDefault()?.Id??1, BrandId=Data.Brands.FirstOrDefault()?.Id??1 }
                         : new Product { Id=p.Id, Name=p.Name, Description=p.Description, Price=p.Price, Stock=p.Stock, ImageUrl=p.ImageUrl, CategoryId=p.CategoryId, CategoryName=p.CategoryName, BrandId=p.BrandId, BrandName=p.BrandName };
        SyncCatName(); SyncBrandName();
        showForm = true;
    }

    void SyncCatName() { form.CategoryName = Data.Categories.FirstOrDefault(c=>c.Id==form.CategoryId)?.Name ?? ""; }
    void SyncBrandName() { form.BrandName = Data.Brands.FirstOrDefault(b=>b.Id==form.BrandId)?.Name ?? ""; }

    void Save()
    {
        if (editing == null) Data.AddProduct(form);
        else Data.UpdateProduct(form);
        CloseForm();
    }
    void DeleteProduct(int id) => Data.DeleteProduct(id);
    void CloseForm() { showForm = false; editing = null; }
}
