@page "/tasks"
@inject DataService Data
@inject AuthService Auth

<div class="page-content">
    <div class="page-toolbar">
        <div class="tb-search-inp" style="padding:8px 16px;color:var(--text-muted)">🔧 My Tasks — @Auth.CurrentUser?.Name</div>
        <select class="tb-filter" @bind="statusFilter">
            <option value="">All Status</option>
            <option value="Assigned">Assigned</option>
            <option value="InProgress">In Progress</option>
            <option value="Completed">Completed</option>
        </select>
    </div>

    <div class="tasks-kanban">
        @foreach (var col in Columns)
        {
            <div class="kanban-col">
                <div class="kanban-header @col.Css">
                    <span>@col.Icon @col.Title</span>
                    <span class="kanban-count">@col.Tasks.Count</span>
                </div>
                @foreach (var t in col.Tasks)
                {
                    <div class="task-card priority-@t.Priority.ToLower()">
                        <div class="tc-top">
                            <span class="tc-order mono">@t.OrderNumber</span>
                            <span class="priority-pill @t.Priority.ToLower()">@t.Priority</span>
                        </div>
                        <div class="tc-customer">@t.CustomerName</div>
                        <div class="tc-desc">@t.Description</div>
                        <div class="tc-date muted">Assigned @t.AssignedAt.ToString("MMM d, yyyy")</div>
                        @if (t.Status != TaskStatusEnum.Completed)
                        {
                            <div class="tc-actions">
                                @if (t.Status == TaskStatusEnum.Assigned)
                                {
                                    <button class="btn-sm-blue" @onclick="() => Data.UpdateTaskStatus(t.Id, TaskStatusEnum.InProgress)">▶ Start</button>
                                }
                                @if (t.Status == TaskStatusEnum.InProgress)
                                {
                                    <button class="btn-sm-green" @onclick="() => Data.UpdateTaskStatus(t.Id, TaskStatusEnum.Completed)">✔ Complete</button>
                                }
                            </div>
                        }
                        else
                        { <div class="tc-done muted">✅ Done @t.CompletedAt?.ToString("MMM d")</div> }
                    </div>
                }
                @if (!col.Tasks.Any())
                { <div class="kanban-empty">No tasks here</div> }
            </div>
        }
    </div>
</div>

@code {
    string statusFilter = "";
    int myId => Auth.CurrentUser?.Id ?? 0;

    List<MechanicTask> MyTasks => Data.Tasks.Where(t => t.MechanicId == myId
        && (string.IsNullOrEmpty(statusFilter) || t.Status.ToString()==statusFilter)).ToList();

    record KanbanCol(string Title, string Icon, string Css, List<MechanicTask> Tasks);

    List<KanbanCol> Columns => new()
    {
        new("Assigned",   "📌", "kh-blue",   MyTasks.Where(t=>t.Status==TaskStatusEnum.Assigned).ToList()),
        new("In Progress","⚙",  "kh-orange",  MyTasks.Where(t=>t.Status==TaskStatusEnum.InProgress).ToList()),
        new("Completed",  "✅", "kh-green",  MyTasks.Where(t=>t.Status==TaskStatusEnum.Completed).ToList()),
    };
}
