@page "/categories"
@inject DataService Data
@inject AuthService Auth

<div class="page-content">
    <div class="page-toolbar">
        <input class="tb-search-inp" type="text" placeholder="🔍 Search categories..." @bind="search" @bind:event="oninput" />
        @if (Auth.HasPermission(p=>p.CanCreateCategories))
        { <button class="btn-primary" @onclick="()=>OpenForm(null)">+ Add Category</button> }
    </div>

    <div class="card">
        <table class="bh-table">
            <thead><tr><th>Icon</th><th>Name</th><th>Description</th><th>Products</th><th>Created</th><th>Actions</th></tr></thead>
            <tbody>
            @foreach (var c in Filtered)
            {
                <tr>
                    <td><span class="tbl-emoji">@c.ImageUrl</span></td>
                    <td class="fw6">@c.Name</td>
                    <td class="muted">@c.Description</td>
                    <td><span class="count-badge">@Data.Products.Count(p=>p.CategoryId==c.Id)</span></td>
                    <td class="muted">@c.CreatedAt.ToString("MMM d, yyyy")</td>
                    <td>
                        @if (Auth.HasPermission(p=>p.CanEditCategories))
                        { <button class="act-btn edit" @onclick="()=>OpenForm(c)">✎</button> }
                        @if (Auth.HasPermission(p=>p.CanDeleteCategories))
                        { <button class="act-btn del" @onclick="()=>Data.DeleteCategory(c.Id)">✕</button> }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@if (showForm)
{
    <div class="modal-overlay" @onclick="Close">
        <div class="modal sm-modal" @onclick:stopPropagation>
            <div class="modal-header">
                <div class="modal-title">@(editing==null?"Add Category":"Edit Category")</div>
                <button class="modal-close" @onclick="Close">✕</button>
            </div>
            <div class="modal-body">
                <div class="form-group"><label>Name *</label><input class="form-input" @bind="form.Name" /></div>
                <div class="form-group"><label>Description</label><input class="form-input" @bind="form.Description" /></div>
                <div class="form-group"><label>Icon (emoji)</label><input class="form-input" @bind="form.ImageUrl" placeholder="🏔️" /></div>
            </div>
            <div class="modal-footer">
                <button class="btn-ghost" @onclick="Close">Cancel</button>
                <button class="btn-primary" @onclick="Save">Save</button>
            </div>
        </div>
    </div>
}

@code {
    string search=""; bool showForm; Category? editing; Category form = new();
    IEnumerable<Category> Filtered => Data.Categories.Where(c=>string.IsNullOrEmpty(search)||c.Name.Contains(search,StringComparison.OrdinalIgnoreCase));
    void OpenForm(Category? c) { editing=c; form=c==null?new():new Category{Id=c.Id,Name=c.Name,Description=c.Description,ImageUrl=c.ImageUrl}; showForm=true; }
    void Save() { if(editing==null) Data.AddCategory(form); else Data.UpdateCategory(form); Close(); }
    void Close() { showForm=false; editing=null; }
}
