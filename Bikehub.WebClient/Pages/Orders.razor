@page "/orders"
@inject DataService Data
@inject AuthService Auth

<div class="page-content">
    <div class="page-toolbar">
        <input class="tb-search-inp" type="text" placeholder="🔍 Search orders..." @bind="search" @bind:event="oninput" />
        <select class="tb-filter" @bind="statusFilter">
            <option value="">All Status</option>
            @foreach (var s in Enum.GetValues<OrderStatus>())
            { <option value="@s">@s</option> }
        </select>
        @if (Auth.HasPermission(p=>p.CanCreateOrders))
        { <button class="btn-primary" @onclick="()=>OpenCreate()">+ New Order</button> }
    </div>

    <div class="card">
        <table class="bh-table">
            <thead><tr><th>Order #</th><th>Customer</th><th>Items</th><th>Total</th><th>Status</th><th>Mechanic</th><th>Date</th><th>Actions</th></tr></thead>
            <tbody>
            @foreach (var o in Filtered.OrderByDescending(x=>x.CreatedAt))
            {
                <tr>
                    <td class="mono accent fw6">@o.OrderNumber</td>
                    <td>@o.CustomerName</td>
                    <td class="muted">@o.Items.Count item(s)</td>
                    <td class="mono fw7">$@o.Total.ToString("N0")</td>
                    <td>
                        @if (Auth.HasPermission(p=>p.CanUpdateOrderStatus))
                        {
                            <select class="status-select @StatusClass(o.Status)" value="@o.Status"
                                    @onchange="e=>UpdateStatus(o.Id, Enum.Parse<OrderStatus>(e.Value!.ToString()!))">
                                @foreach (var s in Enum.GetValues<OrderStatus>())
                                { <option value="@s" selected="@(o.Status==s)">@s</option> }
                            </select>
                        }
                        else
                        { <StatusBadge Status="@o.Status" /> }
                    </td>
                    <td class="muted small">@(o.AssignedMechanicName ?? "—")</td>
                    <td class="muted">@o.CreatedAt.ToString("MMM d")</td>
                    <td>
                        @if (Auth.HasPermission(p=>p.CanDeleteOrders))
                        { <button class="act-btn del" @onclick="()=>Data.DeleteOrder(o.Id)">✕</button> }
                    </td>
                </tr>
            }
            @if (!Filtered.Any())
            { <tr><td colspan="8"><div class="empty-state">No orders found.</div></td></tr> }
            </tbody>
        </table>
    </div>
</div>

@if (showCreate)
{
    <div class="modal-overlay" @onclick="CloseCreate">
        <div class="modal lg-modal" @onclick:stopPropagation>
            <div class="modal-header">
                <div class="modal-title">Create New Order</div>
                <button class="modal-close" @onclick="CloseCreate">✕</button>
            </div>
            <div class="modal-body">
                <div class="form-row two">
                    <div class="form-group">
                        <label>Customer *</label>
                        <select class="form-input" @bind="newOrder.CustomerId" @bind:after="SyncCustomer">
                            <option value="0">Select customer...</option>
                            @foreach (var c in Data.Customers)
                            { <option value="@c.Id">@c.Name</option> }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Assign Mechanic</label>
                        <select class="form-input" @bind="newOrder.AssignedMechanicId" @bind:after="SyncMechanic">
                            <option value="">None</option>
                            @foreach (var u in Data.Users.Where(u=>u.Role==UserRole.Mechanic))
                            { <option value="@u.Id">@u.Name</option> }
                        </select>
                    </div>
                </div>
                <div class="order-items-section">
                    <div class="oi-header">
                        <span class="fw6">Order Items</span>
                        <button class="btn-ghost sm" @onclick="AddItem">+ Add Item</button>
                    </div>
                    @foreach (var item in newOrder.Items)
                    {
                        <div class="oi-row">
                            <select class="form-input" @bind="item.ProductId" @bind:after="()=>SyncItem(item)">
                                <option value="0">Select product...</option>
                                @foreach (var p in Data.Products)
                                { <option value="@p.Id">@p.Name — $@p.Price</option> }
                            </select>
                            <input class="form-input qty" type="number" min="1" @bind="item.Quantity" @bind:after="()=>SyncItem(item)" />
                            <span class="item-subtotal">$@item.Subtotal.ToString("N0")</span>
                            <button class="act-btn del" @onclick="()=>newOrder.Items.Remove(item)">✕</button>
                        </div>
                    }
                    @if (!newOrder.Items.Any()) { <div class="oi-empty">Add at least one item.</div> }
                </div>
                <div class="order-total-row">
                    <span>Order Total</span>
                    <span class="order-total-val">$@newOrder.Items.Sum(i=>i.Subtotal).ToString("N0")</span>
                </div>
                <div class="form-group">
                    <label>Notes</label>
                    <textarea class="form-input" rows="2" @bind="newOrder.Notes"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-ghost" @onclick="CloseCreate">Cancel</button>
                <button class="btn-primary" @onclick="SaveOrder"
                        disabled="@(newOrder.CustomerId==0||!newOrder.Items.Any())">
                    Create Order
                </button>
            </div>
        </div>
    </div>
}

@code {
    string search="", statusFilter="";
    bool showCreate;
    Order newOrder = new();

    IEnumerable<Order> Filtered => Data.Orders
        .Where(o => string.IsNullOrEmpty(search) || o.OrderNumber.Contains(search,StringComparison.OrdinalIgnoreCase) || o.CustomerName.Contains(search,StringComparison.OrdinalIgnoreCase))
        .Where(o => string.IsNullOrEmpty(statusFilter) || o.Status.ToString()==statusFilter);

    void UpdateStatus(int id, OrderStatus s) => Data.UpdateOrderStatus(id, s);

    string StatusClass(OrderStatus s) => s switch
    {
        OrderStatus.Pending        => "ss-pending",
        OrderStatus.Completed      => "ss-completed",
        OrderStatus.InService      => "ss-inservice",
        OrderStatus.Cancelled      => "ss-cancelled",
        _ => ""
    };

    void OpenCreate() { newOrder = new Order { Items = new() }; showCreate = true; }
    void CloseCreate() { showCreate = false; }
    void AddItem() => newOrder.Items.Add(new OrderItem { Quantity = 1 });
    void SyncCustomer() { newOrder.CustomerName = Data.Customers.FirstOrDefault(c=>c.Id==newOrder.CustomerId)?.Name ?? ""; }
    void SyncMechanic() { newOrder.AssignedMechanicName = Data.Users.FirstOrDefault(u=>u.Id==newOrder.AssignedMechanicId)?.Name; }
    void SyncItem(OrderItem item)
    {
        var p = Data.Products.FirstOrDefault(x=>x.Id==item.ProductId);
        if (p != null) { item.ProductName = p.Name; item.UnitPrice = p.Price; }
    }
    void SaveOrder() { Data.AddOrder(newOrder); CloseCreate(); }
}
